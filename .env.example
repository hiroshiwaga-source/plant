# Copy to .env locally (never commit .env with real values).
# EXPO_PUBLIC_* is embedded in the client bundle — public by design.

# Supabase (safe to expose in client — security depends on RLS + Auth)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Vitest RLS integration tests (optional — not EXPO_PUBLIC; do not ship in the app)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=your_anon_key_here
# Optional: avoids Auth "email rate limit" on signUp; integration tests only, never in the app
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- Server-side only (Supabase Edge Functions secrets / CI — NOT for Expo EXPO_PUBLIC) ---
# Set via: supabase secrets set KEY=value
# (Same service_role as above — still never use in Expo EXPO_PUBLIC_*)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# PLANTID_API_KEY=
# KINDWISE_API_KEY=
