# Copy to .env locally (never commit .env with real values).
# EXPO_PUBLIC_* is embedded in the client bundle — public by design.

# Supabase (safe to expose in client — security depends on RLS + Auth)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: public HTTPS page opened after tapping "confirm email" in the inbox.
# Use when testing on a phone (localhost Site URL will fail). Must be listed in
# Supabase Dashboard → Authentication → URL Configuration → Redirect URLs.
# EXPO_PUBLIC_AUTH_EMAIL_REDIRECT_URL=https://your-domain.example/auth/confirmed.html

# Vitest RLS integration tests — prefer a separate file so Expo never loads service_role:
# Create .env.test.local (gitignored) with:
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=your_publishable_or_anon_key_here
# SUPABASE_SERVICE_ROLE_KEY=legacy_service_role_jwt_here

# --- Server-side only (Supabase Edge Functions secrets / CI — NOT for Expo EXPO_PUBLIC) ---
# Set via: supabase secrets set KEY=value
# (Same service_role as above — still never use in Expo EXPO_PUBLIC_*)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# PLANTID_API_KEY=
# KINDWISE_API_KEY=
